# ─── Server ───────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
# Comma-separated list of allowed origins for CORS (mobile uses LAN IP).
# Use * during local development if unsure.
CORS_ORIGIN=*

# ─── Database (PostgreSQL) ──────────────────────────────────────────────────
# Either set DATABASE_URL, or the individual PG* vars below.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/staymate
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=postgres
# PGDATABASE=staymate

# ─── Auth ───────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=30d

# ─── Media storage ──────────────────────────────────────────────────────────
# Driver: "local" (saves to disk + JSON metadata) or "contabo" (S3-compatible).
STORAGE_DRIVER=local

# Public base URL used to build full image URLs returned to clients.
# For local driver, files are served from <PUBLIC_BASE_URL>/uploads/<key>.
# Set this to your machine's LAN IP so the mobile app can load images.
PUBLIC_BASE_URL=http://localhost:4000

# ─── Contabo Object Storage (S3-compatible) — fill in after purchase ────────
# Leave blank while using STORAGE_DRIVER=local.
CONTABO_ENDPOINT=
CONTABO_REGION=
CONTABO_BUCKET=
CONTABO_ACCESS_KEY=
CONTABO_SECRET_KEY=
# Public URL of the bucket (e.g. https://eu2.contabostorage.com/<bucket>)
CONTABO_PUBLIC_URL=
