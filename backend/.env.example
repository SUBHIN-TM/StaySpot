# ─── Server ───────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
# Comma-separated list of allowed origins for CORS (mobile uses LAN IP).
# Use * during local development if unsure.
CORS_ORIGIN=*

# ─── Database (PostgreSQL) ──────────────────────────────────────────────────
# Either set DATABASE_URL, or the individual PG* vars below.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/staymate
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=postgres
# PGDATABASE=staymate

# ─── Auth ───────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=30d

# ─── Media storage ──────────────────────────────────────────────────────────
# Driver: "contabo" (S3-compatible object storage) or "local" (disk + JSON).
STORAGE_DRIVER=contabo

# Only for the "local" driver: base URL used to build <PUBLIC_BASE_URL>/uploads/<key>
# image URLs. Defaults to http://localhost:4000 if unset; set to your LAN IP for
# the mobile app. Not needed when STORAGE_DRIVER=contabo.
# PUBLIC_BASE_URL=http://localhost:4000

# ─── Contabo Object Storage (S3-compatible) ─────────────────────────────────
# Credentials from my.contabo.com → Object Storage (S3 access keys).
CONTABO_ENDPOINT=https://eu2.contabostorage.com         # endpoint only — no bucket
CONTABO_REGION=eu2                                       # region code from the endpoint host
CONTABO_BUCKET=
CONTABO_ACCESS_KEY=
CONTABO_SECRET_KEY=
# Public URL = endpoint + "/<tenant-id>:<bucket>"
# e.g. https://eu2.contabostorage.com/<tenant-id>:<bucket>
CONTABO_PUBLIC_URL=
